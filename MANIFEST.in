# MANIFEST.in
# ETLPlus
#
# Copyright © 2026 Dagitali LLC. All rights reserved.
#
# Setuptools source distribution manifest rules.
#
# Setuptools is the Python packaging build backend this project uses to turn
# the source tree into installable artifacts, mainly:
# - Source distributions: sdist, usually .tar.gz
# - Built wheels: .whl
#
# Responsibilities
# - Include package template files that are required at runtime.
# - Keep source distributions focused on supported source and packaging inputs.
# - Exclude local scratch files, generated outputs, and temporary release
#   artifacts from published source archives.
#
# Maintainer Notes
# - `pyproject.toml` remains the canonical packaging metadata source.
# - Keep package-data includes aligned with runtime imports and template lookup
#   paths.
# - Preserve release-artifact exclusions unless the release packaging policy
#   intentionally changes.
#
# References
# - Setuptools manifest documentation: https://setuptools.pypa.io/en/latest/userguide/miscellaneous.html

# Include Jinja template files in the etlplus package
recursive-include etlplus/templates *.j2

# Keep release artifacts focused on the supported source tree.
prune build
prune docs/_build
prune out
prune temp
exclude export.json
exclude MONETIZATION.md
exclude out.json
exclude output.csv
exclude output.json
exclude roadmap.md
exclude result.json
global-exclude *_FIXED.* *_NEW.* *_ORIG.*
